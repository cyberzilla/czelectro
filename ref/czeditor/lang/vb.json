{
  "id": "vb",
  "name": "Visual Basic",
  "extensions": ["vb","vbs","bas","cls","frm"],
  "comment": {"line":"'","blockStart":null,"blockEnd":null},
  "autoClosePairs": [["(",")"],["\"","\""]],
  "brackets": [["(",")"]],
  "syntax": [
    {"match":"\"(?:[^\"]|\"\")*\"","scope":"string"},
    {"match":"'.*$","scope":"comment","flags":"m"},
    {"match":"\\bREM\\b.*$","scope":"comment","flags":"mi"},
    {"match":"\\b(?:AddHandler|AddressOf|Alias|And|AndAlso|As|Boolean|ByRef|Byte|ByVal|Call|Case|Catch|CBool|CByte|CChar|CDate|CDbl|CDec|Char|CInt|Class|CLng|CObj|Const|Continue|CSByte|CShort|CSng|CStr|CType|CUInt|CULng|CUShort|Date|Decimal|Declare|Default|Delegate|Dim|DirectCast|Do|Double|Each|Else|ElseIf|End|EndIf|Enum|Erase|Error|Event|Exit|False|Finally|For|Friend|Function|Get|GetType|GetXMLNamespace|Global|GoSub|GoTo|Handles|If|Implements|Imports|In|Inherits|Integer|Interface|Is|IsNot|Let|Lib|Like|Long|Loop|Me|Mod|Module|MustInherit|MustOverride|MyBase|MyClass|Namespace|Narrowing|New|Next|Not|Nothing|NotInheritable|NotOverridable|Object|Of|On|Operator|Option|Optional|Or|OrElse|Out|Overloads|Overridable|Overrides|ParamArray|Partial|Private|Property|Protected|Public|RaiseEvent|ReadOnly|ReDim|RemoveHandler|Resume|Return|SByte|Select|Set|Shadows|Shared|Short|Single|Static|Step|Stop|String|Structure|Sub|SyncLock|Then|Throw|To|True|Try|TryCast|TypeOf|UInteger|ULong|UShort|Using|Variant|Wend|When|While|Widening|With|WithEvents|WriteOnly|Xor)\\b","scope":"keyword","flags":"i"},
    {"match":"\\b(?:True|False|Nothing|Me|MyBase|MyClass)\\b","scope":"constant","flags":"i"},
    {"match":"\\b(?:Console|Debug|Math|Convert|Array|DateTime|TimeSpan|Environment|IO|Text|Threading|Diagnostics|MsgBox|InputBox)\\b","scope":"type"},
    {"match":"\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()","scope":"function"},
    {"match":"\\b\\d+\\.?\\d*(?:[eE][+-]?\\d+)?[fFdDlL]?\\b|&[hH][0-9a-fA-F]+|&[oO][0-7]+|&[bB][01]+","scope":"number"},
    {"match":"<>|<=|>=|<<=|>>=|\\+=|-=|\\*=|/=|\\\\=|\\^=|&=","scope":"operator"}
  ],
  "autocomplete": {
    "keywords": ["Boolean","Byte","Call","Case","Catch","Class","Const","Continue","Date","Decimal","Declare","Dim","Do","Double","Each","Else","ElseIf","End","Enum","Exit","False","Finally","For","Function","Get","GoTo","If","Implements","Imports","In","Integer","Interface","Is","Long","Loop","Me","Module","Namespace","New","Next","Not","Nothing","Object","Of","Optional","Or","Private","Property","Protected","Public","ReDim","Return","Select","Set","Short","Single","Static","Step","String","Structure","Sub","Then","Throw","To","True","Try","Using","While","With"],
    "builtins": ["Console.WriteLine","Console.ReadLine","Console.Write","MsgBox","InputBox","Debug.Print","Debug.WriteLine","Math.Max","Math.Min","Math.Abs","Math.Sqrt","Convert.ToInt32","Convert.ToString","Convert.ToDouble","Array.Sort","String.Format","String.Join"]
  },
  "snippets": {
    "sub": {"body":"Sub $1()\n\t$2\nEnd Sub","description":"Subroutine"},
    "func": {"body":"Function $1() As $2\n\t$3\nEnd Function","description":"Function"},
    "if": {"body":"If $1 Then\n\t$2\nEnd If","description":"If block"},
    "ifelse": {"body":"If $1 Then\n\t$2\nElse\n\t$3\nEnd If","description":"If-Else"},
    "for": {"body":"For $1 = $2 To $3\n\t$4\nNext","description":"For loop"},
    "foreach": {"body":"For Each $1 In $2\n\t$3\nNext","description":"For Each"},
    "select": {"body":"Select Case $1\n\tCase $2\n\t\t$3\n\tCase Else\n\t\t$4\nEnd Select","description":"Select Case"},
    "try": {"body":"Try\n\t$1\nCatch ex As Exception\n\t$2\nEnd Try","description":"Try-Catch"}
  }
}
