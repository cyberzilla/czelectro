{
  "id": "css",
  "name": "CSS",
  "extensions": [
    "css",
    "scss",
    "less"
  ],
  "comment": {
    "line": null,
    "blockStart": "/*",
    "blockEnd": "*/"
  },
  "autoClosePairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "syntax": [
    {
      "match": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "scope": "string"
    },
    {
      "match": "'(?:[^'\\\\]|\\\\.)*'",
      "scope": "string"
    },
    {
      "match": "\\/\\*\\*[\\\\s\\\\S]*?\\*\\/",
      "scope": "doccomment"
    },
    {
      "match": "\\/\\*[\\s\\S]*?\\*\\/",
      "scope": "comment"
    },
    {
      "match": "@[a-zA-Z-]+",
      "scope": "keyword"
    },
    {
      "match": "!important",
      "scope": "keyword"
    },
    {
      "match": ":[a-zA-Z-]+(?:\\([^)]*\\))?",
      "scope": "pseudo"
    },
    {
      "match": "[.#][a-zA-Z_-][a-zA-Z0-9_-]*",
      "scope": "selector"
    },
    {
      "match": "\\b[a-zA-Z-]+(?=\\s*:)",
      "scope": "property"
    },
    {
      "match": "#[0-9a-fA-F]{3,8}\\b",
      "scope": "color"
    },
    {
      "match": "\\b\\d+\\.?\\d*(?:px|em|rem|vh|vw|%|pt|fr|deg|s|ms)\\b",
      "scope": "number"
    },
    {
      "match": "\\b\\d+\\.?\\d*\\b",
      "scope": "number"
    }
  ],
  "autocomplete": {
    "keywords": [
      "@media",
      "@keyframes",
