{
  "id": "kotlin",
  "name": "Kotlin",
  "extensions": [
    "kt",
    "kts"
  ],
  "comment": {
    "line": "//",
    "blockStart": "/*",
    "blockEnd": "*/"
  },
  "autoClosePairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "syntax": [
    {
      "match": "\"\"\"[\\s\\S]*?\"\"\"",
      "scope": "string"
    },
    {
      "match": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "scope": "string"
    },
    {
      "match": "'(?:[^'\\\\]|\\\\.)*'",
      "scope": "string"
    },
    {
      "match": "//.*$",
      "scope": "comment",
      "flags": "m"
    },
    {
      "match": "/\\*\\*[\\s\\S]*?\\*/",
      "scope": "doccomment"
    },
    {
      "match": "/\\*[\\s\\S]*?\\*/",
      "scope": "comment"
    },
    {
      "match": "@[A-Za-z_][A-Za-z0-9_.]*",
      "scope": "decorator"
    },
    {
      "match": "\\b(?:abstract|actual|annotation|as|break|by|catch|class|companion|const|constructor|continue|crossinline|data|delegate|do|dynamic|else|enum|expect|external|final|finally|for|fun|get|if|import|in|infix|init|inline|inner|interface|internal|is|lateinit|noinline|object|open|operator|out|override|package|private|protected|public|reified|return|sealed|set|super|suspend|tailrec|this|throw|try|typealias|val|var|vararg|when|where|while|yield)\\b",
      "scope": "keyword"
    },
    {
      "match": "\\b(?:true|false|null)\\b",
      "scope": "constant"
    },
    {
      "match": "\\b(?:Any|Boolean|Byte|Char|Double|Float|Int|Long|Nothing|Short|String|Unit|Array|List|Map|Set|MutableList|MutableMap|MutableSet|Pair|Triple|Sequence|Comparable|Iterable|Collection|Throwable|Exception|Error|Regex)\\b",
      "scope": "type"
    },
    {
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
      "scope": "type"
    },
    {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*[({])",
      "scope": "function"
    },
    {
      "match": "\\$\\{[^}]*\\}|\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "scope": "variable"
    },
    {
      "match": "\\b0[xX][0-9a-fA-F_]+[uUlL]*\\b|\\b\\d[\\d_]*\\.?[\\d_]*(?:[eE][+-]?\\d+)?[fFuUlL]*\\b",
      "scope": "number"
    },
    {
      "match": "->|\\?\\.|\\?:|::|\\.\\.|\\.\\.<|!!|&&|\\|\\||!=|==|===|!==|<=|>=",
      "scope": "operator"
    }
  ],
  "autocomplete": {
    "keywords": [
      "abstract",
      "class",
      "companion",
      "const",
      "constructor",
      "data",
      "else",
      "enum",
      "for",
      "fun",
      "if",
      "import",
      "in",
      "interface",
      "internal",
      "is",
      "lateinit",
      "object",
      "open",
      "override",
      "package",
      "private",
      "protected",
      "public",
      "return",
      "sealed",
      "super",
      "suspend",
      "this",
      "throw",
      "try",
      "val",
      "var",
      "when",
      "while"
    ],
    "builtins": [
      "println",
      "print",
      "readLine",
      "listOf",
      "mutableListOf",
      "mapOf",
      "mutableMapOf",
      "setOf",
      "mutableSetOf",
      "arrayOf",
      "emptyList",
      "emptyMap",
      "emptySet",
      "require",
      "check",
      "error",
      "TODO",
      "run",
      "let",
      "also",
      "apply",
      "with",
      "takeIf",
      "takeUnless",
      "repeat",
      "lazy",
      "sequence",
      "buildList",
      "buildMap",
      "buildString"
    ]
  },
  "snippets": {
    "fun": {
      "body": "fun $1($2): $3 {\n\t$4\n}",
      "description": "Function"
    },
    "main": {
      "body": "fun main(args: Array<String>) {\n\t$1\n}",
      "description": "Main function"
    },
    "ifelse": {
      "body": "if ($1) {\n\t$2\n} else {\n\t$3\n}",
      "description": "If-else"
    },
    "when": {
      "body": "when ($1) {\n\t$2 -> $3\n\telse -> $4\n}",
      "description": "When expression"
    },
    "data": {
      "body": "data class $1(\n\tval $2: $3\n)",
      "description": "Data class"
    },
    "try": {
      "body": "try {\n\t$1\n} catch (e: Exception) {\n\t$2\n}",
      "description": "Try-catch"
    }
  }
}