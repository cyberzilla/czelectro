{
  "id": "env",
  "name": "Environment",
  "extensions": ["env"],
  "filenames": [".env", ".env.local", ".env.development", ".env.production", ".env.staging", ".env.test", ".env.example"],
  "comment": { "line": "#", "blockStart": null, "blockEnd": null },
  "autoClosePairs": [
    ["\"", "\""], ["'", "'"],
    ["{", "}"], ["(", ")"]
  ],
  "brackets": [["{", "}"], ["(", ")"]],
  "syntax": [
    { "match": "\"(?:[^\"\\\\]|\\\\.)*\"", "scope": "string" },
    { "match": "'(?:[^'\\\\]|\\\\.)*'", "scope": "string" },
    { "match": "#[^\\n]*", "scope": "comment" },
    { "match": "^[A-Z_][A-Z0-9_]*(?=\\s*=)", "scope": "property", "flags": "m" },
    { "match": "\\$\\{[A-Z_][A-Z0-9_]*\\}", "scope": "class" },
    { "match": "\\$[A-Z_][A-Z0-9_]*", "scope": "class" },
    { "match": "\\b(?:true|false|yes|no|on|off|null|none)\\b", "scope": "keyword", "flags": "i" },
    { "match": "\\b\\d+\\.?\\d*\\b", "scope": "number" },
    { "match": "(?:https?|ftp|mysql|postgres|redis|mongodb|smtp|amqp)://[^\\s\"']+", "scope": "attr" }
  ],
  "autocomplete": {
    "keywords": ["true", "false", "null", "yes", "no"],
    "builtins": [
      "APP_NAME", "APP_ENV", "APP_KEY", "APP_DEBUG", "APP_URL", "APP_PORT",
      "DB_CONNECTION", "DB_HOST", "DB_PORT", "DB_DATABASE", "DB_USERNAME", "DB_PASSWORD",
      "REDIS_HOST", "REDIS_PASSWORD", "REDIS_PORT",
      "MAIL_MAILER", "MAIL_HOST", "MAIL_PORT", "MAIL_USERNAME", "MAIL_PASSWORD", "MAIL_ENCRYPTION", "MAIL_FROM_ADDRESS", "MAIL_FROM_NAME",
      "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_DEFAULT_REGION", "AWS_BUCKET",
      "CACHE_DRIVER", "SESSION_DRIVER", "QUEUE_CONNECTION",
      "LOG_CHANNEL", "LOG_LEVEL",
      "BROADCAST_DRIVER", "FILESYSTEM_DISK",
      "NODE_ENV", "PORT", "HOST",
      "JWT_SECRET", "JWT_TTL",
      "API_KEY", "API_SECRET", "API_URL",
      "VITE_APP_TITLE", "NEXT_PUBLIC_API_URL"
    ]
  },
  "snippets": {
    "db": { "body": "DB_CONNECTION=$1\nDB_HOST=127.0.0.1\nDB_PORT=$2\nDB_DATABASE=$3\nDB_USERNAME=$4\nDB_PASSWORD=$5", "description": "Database Config" },
    "mail": { "body": "MAIL_MAILER=smtp\nMAIL_HOST=$1\nMAIL_PORT=$2\nMAIL_USERNAME=$3\nMAIL_PASSWORD=$4\nMAIL_ENCRYPTION=tls\nMAIL_FROM_ADDRESS=$5\nMAIL_FROM_NAME=\"${APP_NAME}\"", "description": "Mail Config" },
    "redis": { "body": "REDIS_HOST=127.0.0.1\nREDIS_PASSWORD=null\nREDIS_PORT=6379", "description": "Redis Config" },
    "aws": { "body": "AWS_ACCESS_KEY_ID=$1\nAWS_SECRET_ACCESS_KEY=$2\nAWS_DEFAULT_REGION=$3\nAWS_BUCKET=$4", "description": "AWS Config" }
  }
}
