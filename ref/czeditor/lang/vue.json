      "createApp",
      "defineComponent",
      "defineAsyncComponent",
      "h",
      "resolveComponent",
      "resolveDirective",
      "Teleport",
      "Transition",
      "TransitionGroup",
      "KeepAlive",
      "Suspense",
      "template",
      "script",
      "style",
      "setup",
      "v-if",
