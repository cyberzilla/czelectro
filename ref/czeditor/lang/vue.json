{
  "id": "vue",
  "name": "Vue",
  "extensions": [
    "vue"
  ],
  "comment": {
    "line": null,
    "blockStart": "<!--",
    "blockEnd": "-->"
  },
  "autoClosePairs": [
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ],
    [
      "`",
      "`"
    ],
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoCloseTag": true,
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "syntax": [
    {
      "match": "`(?:[^`\\\\]|\\\\.)*`",
      "scope": "string"
    },
    {
      "match": "\"(?:[^\"\\\\\\n]|\\\\.)*\"",
      "scope": "string"
    },
    {
      "match": "'(?:[^'\\\\\\n]|\\\\.)*'",
      "scope": "string"
    },
    {
      "match": "<!--[\\s\\S]*?-->",
      "scope": "comment"
    },
    {
      "match": "\\/\\/[^\\n]*",
      "scope": "comment"
    },
    {
      "match": "\\/\\*\\*[\\\\s\\\\S]*?\\*\\/",
      "scope": "doccomment"
    },
    {
      "match": "\\/\\*[\\s\\S]*?\\*\\/",
      "scope": "comment"
    },
    {
      "match": "\\b(?:const|let|var|function|return|if|else|for|while|do|switch|case|break|continue|class|extends|import|export|default|from|as|new|delete|typeof|instanceof|in|of|try|catch|finally|throw|async|await|yield|static|true|false|null|undefined|void|this|template|script|style|setup|props|emits|defineProps|defineEmits|defineExpose|defineOptions|ref|reactive|computed|watch|watchEffect|onMounted|onUnmounted|onUpdated|onBeforeMount|onBeforeUnmount|onBeforeUpdate|nextTick|provide|inject|readonly|toRef|toRefs|shallowRef|shallowReactive|triggerRef|customRef|unref|isRef|toRaw|markRaw|effectScope)\\b",
      "scope": "keyword"
    },
    {
      "match": "(?<=<\\/?)([A-Z][a-zA-Z0-9]*)",
      "scope": "class"
    },
    {
      "match": "(?<=<\\/?)([a-z][a-zA-Z0-9-]*)",
      "scope": "tag"
    },
    {
      "match": "\\b([a-zA-Z-]+)(?=\\s*=)",
      "scope": "attr"
    },
    {
      "match": "(?:v-if|v-else-if|v-else|v-for|v-show|v-model|v-bind|v-on|v-slot|v-pre|v-once|v-cloak|v-memo|v-html|v-text)",
      "scope": "keyword"
    },
    {
      "match": "(?:@[a-zA-Z.-]+|:[a-zA-Z.-]+|#[a-zA-Z.-]+)",
      "scope": "attr"
    },
    {
      "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "match": "\\b(?:0x[0-9a-fA-F]+|0b[01]+|0o[0-7]+|\\d+\\.?\\d*(?:e[+-]?\\d+)?)\\b",
      "scope": "number"
    },
    {
      "match": "[<>/=]",
      "scope": "punctuation"
    }
  ],
  "autocomplete": {
    "keywords": [
      "async",
      "await",
      "break",
      "case",
      "catch",
      "class",
      "const",
      "continue",
