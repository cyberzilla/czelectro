      "fetch",
      "Promise",
      "JSON"
    ]
  },
  "snippets": {
    "vbase": {
      "body": "<template>\n\t<div>\n\t\t$1\n\t</div>\n</template>\n\n<script setup>\n$2\n</script>\n\n<style scoped>\n$3\n</style>",
      "description": "Vue 3 SFC Base"
    },
    "vbase-ts": {
      "body": "<template>\n\t<div>\n\t\t$1\n\t</div>\n</template>\n\n<script setup lang=\"ts\">\n$2\n</script>\n\n<style scoped>\n$3\n</style>",
      "description": "Vue 3 SFC TypeScript"
    },
    "vref": {
      "body": "const $1 = ref($2);",
      "description": "Vue Ref"
    },
    "vreactive": {
      "body": "const $1 = reactive({\n\t$2\n});",
      "description": "Vue Reactive"
    },
    "vcomputed": {
      "body": "const $1 = computed(() => {\n\treturn $2;\n});",
      "description": "Vue Computed"
    },
    "vwatch": {
      "body": "watch($1, ($2, $3) => {\n\t$4\n});",
      "description": "Vue Watch"
    },
    "vwatcheffect": {
      "body": "watchEffect(() => {\n\t$1\n});",
      "description": "Vue WatchEffect"
    },
    "vonmounted": {
      "body": "onMounted(() => {\n\t$1\n});",
      "description": "Vue onMounted"
    },
    "vonunmounted": {
      "body": "onUnmounted(() => {\n\t$1\n});",
      "description": "Vue onUnmounted"
    },
    "vprops": {
      "body": "const props = defineProps<{\n\t$1: $2;\n}>();",
      "description": "Vue defineProps"
    },
    "vemits": {
      "body": "const emit = defineEmits<{\n\t$1: [$2];\n}>();",
      "description": "Vue defineEmits"
    },
    "vfor": {
      "body": "v-for=\"$1 in $2\" :key=\"$3\"",
      "description": "v-for"
    },
    "vif": {
      "body": "v-if=\"$1\"",
      "description": "v-if"
    },
    "vmodel": {
      "body": "v-model=\"$1\"",
      "description": "v-model"
    },
    "imp": {
      "body": "import $1 from '$2';",
      "description": "Import"
    },
    "impa": {
      "body": "import { $1 } from '$2';",
      "description": "Import Named"
    }
  },
  "voidTags": [
    "area",
    "base",
    "br",
    "col",
    "embed",
    "hr",
    "img",
    "input",
    "link",
    "meta",
    "param",
    "source",
    "track",
    "wbr"
  ]
}