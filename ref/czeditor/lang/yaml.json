{
  "id": "yaml",
  "name": "YAML",
  "extensions": ["yml","yaml"],
  "comment": {"line":"#","blockStart":null,"blockEnd":null},
  "autoClosePairs": [["[","]"],["{","}"],["\"","\""],["'","'"]],
  "brackets": [["[","]"],["{","}"]],
  "syntax": [
    {"match":"\"(?:[^\"\\\\]|\\\\.)*\"","scope":"string"},
    {"match":"'(?:[^']|'')*'","scope":"string"},
    {"match":"#.*$","scope":"comment","flags":"m"},
    {"match":"^\\s*[a-zA-Z_][a-zA-Z0-9_.\\-]*(?=\\s*:)","scope":"property","flags":"m"},
    {"match":"\\b(?:true|false|yes|no|on|off|null|~)\\b","scope":"constant","flags":"i"},
    {"match":"[|>][+-]?\\s*$","scope":"operator","flags":"m"},
    {"match":"---\\s*$|\\.\\.\\.","scope":"keyword","flags":"m"},
    {"match":"<<|&[a-zA-Z_][a-zA-Z0-9_]*|\\*[a-zA-Z_][a-zA-Z0-9_]*","scope":"variable"},
    {"match":"!![a-zA-Z]+|![a-zA-Z_][a-zA-Z0-9_/]*","scope":"type"},
    {"match":"\\b\\d+\\.?\\d*(?:[eE][+-]?\\d+)?\\b","scope":"number"}
  ],
  "autocomplete": {
    "keywords": ["true","false","null","yes","no"],
    "builtins": []
  },
  "snippets": {
  }
}
