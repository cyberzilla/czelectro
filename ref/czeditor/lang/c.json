    ]
  },
  "snippets": {
    "inc": {
      "body": "#include <$1>",
      "description": "Include header"
    },
    "main": {
      "body": "int main(int argc, char *argv[]) {\n\t$1\n\treturn 0;\n}",
      "description": "Main function"
    },
    "for": {
      "body": "for (int i = 0; i < $1; i++) {\n\t$2\n}",
      "description": "For loop"
    },
    "class": {
      "body": "class $1 {\npublic:\n\t$1();\n\t~$1();\nprivate:\n\t$2\n};",
      "description": "Class"
    },
    "struct": {
      "body": "struct $1 {\n\t$2\n};",
      "description": "Struct"
    }
  }
}