{
  "id": "javascript",
  "name": "JavaScript",
  "extensions": ["js","mjs","cjs"],
  "comment": {"line":"//","blockStart":"/*","blockEnd":"*/"},
  "autoClosePairs": [["{","}"],["[","]"],["(",")"],["\"","\""],["'","'"],["`","`"]],
  "brackets": [["{","}"],["[","]"],["(",")"]],
  "syntax": [
    {"match":"`(?:[^`\\\\]|\\\\.)*`","scope":"string"},
    {"match":"\"(?:[^\"\\\\\\n]|\\\\.)*\"","scope":"string"},
    {"match":"'(?:[^'\\\\\\n]|\\\\.)*'","scope":"string"},
    {"match":"\\/\\/[^\\n]*","scope":"comment"},
    {"match":"\\/\\*\\*[\\s\\S]*?\\*\\/","scope":"doccomment"},
    {"match":"\\/\\*[\\s\\S]*?\\*\\/","scope":"comment"},
    {"match":"\\/(?![\\/*])(?:[^\\/\\\\\\n]|\\\\.)+\\/[gimsuy]*","scope":"regex"},
    {"match":"\\b(?:const|let|var|function|return|if|else|for|while|do|switch|case|break|continue|class|extends|super|import|export|default|from|as|new|delete|typeof|instanceof|in|of|try|catch|finally|throw|async|await|yield|static|get|set|true|false|null|undefined|void|this|with|debugger)\\b","scope":"keyword"},
    {"match":"\\b[A-Z][a-zA-Z0-9_$]*\\b","scope":"class"},
    {"match":"\\b[a-zA-Z_$][a-zA-Z0-9_$]*(?=\\s*\\()","scope":"function"},
    {"match":"\\b(?:0x[0-9a-fA-F]+|0b[01]+|0o[0-7]+|\\d+\\.?\\d*(?:e[+-]?\\d+)?)\\b","scope":"number"},
    {"match":"(?:=>|\\.\\.\\.|===|!==|==|!=|<=|>=|&&|\\|\\||\\?\\?|\\?\\.|\\+\\+|--|\\+=|-=|\\*=|\\/=|%=|\\*\\*=|<<=|>>=|>>>=|&=|\\|=|\\^=)","scope":"operator"}
  ],
  "autocomplete": {
    "keywords": ["async","await","break","case","catch","class","const","continue","debugger","default","delete","do","else","export","extends","false","finally","for","function","if","import","in","instanceof","let","new","null","of","return","static","super","switch","this","throw","true","try","typeof","undefined","var","void","while","with","yield"],
    "builtins": ["console","document","window","navigator","location","history","localStorage","sessionStorage","fetch","setTimeout","setInterval","clearTimeout","clearInterval","requestAnimationFrame","Promise","JSON","Math","Date","RegExp","Error","Map","Set","WeakMap","WeakSet","Symbol","Proxy","Reflect","Array","Object","String","Number","Boolean","parseInt","parseFloat","isNaN","isFinite","encodeURI","decodeURI","encodeURIComponent","alert","confirm","prompt","atob","btoa","addEventListener","removeEventListener","querySelector","querySelectorAll","getElementById","getElementsByClassName","createElement","appendChild","removeChild","insertBefore","replaceChild","getAttribute","setAttribute","removeAttribute","classList","innerHTML","textContent","style","parentNode","childNodes","children","parentElement","console.log","console.error","console.warn","console.info"]
  },
  "snippets": {
    "clg": {"body":"console.log($1);","description":"Console Log"},
    "cle": {"body":"console.error($1);","description":"Console Error"},
    "clw": {"body":"console.warn($1);","description":"Console Warn"},
    "clt": {"body":"console.table($1);","description":"Console Table"},
    "fun": {"body":"function $1($2) {\n\t$3\n}","description":"Function"},
    "afn": {"body":"const $1 = ($2) => {\n\t$3\n};","description":"Arrow Function"},
    "iife": {"body":"(function() {\n\t$1\n})();","description":"IIFE"},
    "for": {"body":"for (let i = 0; i < $1; i++) {\n\t$2\n}","description":"For Loop"},
    "fore": {"body":"$1.forEach(($2) => {\n\t$3\n});","description":"forEach"},
    "forin": {"body":"for (const $1 in $2) {\n\t$3\n}","description":"For...in"},
    "forof": {"body":"for (const $1 of $2) {\n\t$3\n}","description":"For...of"},
    "if": {"body":"if ($1) {\n\t$2\n}","description":"If"},
    "ife": {"body":"if ($1) {\n\t$2\n} else {\n\t$3\n}","description":"If...Else"},
    "sw": {"body":"switch ($1) {\n\tcase $2:\n\t\t$3\n\t\tbreak;\n\tdefault:\n\t\t$4\n}","description":"Switch"},
    "tc": {"body":"try {\n\t$1\n} catch ($2) {\n\t$3\n}","description":"Try...Catch"},
    "tcf": {"body":"try {\n\t$1\n} catch ($2) {\n\t$3\n} finally {\n\t$4\n}","description":"Try...Catch...Finally"},
    "prom": {"body":"new Promise((resolve, reject) => {\n\t$1\n});","description":"Promise"},
    "cls": {"body":"class $1 {\n\tconstructor($2) {\n\t\t$3\n\t}\n}","description":"Class"},
    "imp": {"body":"import $1 from '$2';","description":"Import"},
    "impa": {"body":"import { $1 } from '$2';","description":"Import Named"},
    "exp": {"body":"export default $1;","description":"Export Default"},
    "expn": {"body":"export const $1 = $2;","description":"Export Named"},
    "map": {"body":"$1.map(($2) => $3)","description":"Array Map"},
    "filter": {"body":"$1.filter(($2) => $3)","description":"Array Filter"},
    "reduce": {"body":"$1.reduce(($2, $3) => $4, $5)","description":"Array Reduce"},
    "ael": {"body":"$1.addEventListener('$2', ($3) => {\n\t$4\n});","description":"Event Listener"},
    "qs": {"body":"document.querySelector('$1')","description":"querySelector"},
    "qsa": {"body":"document.querySelectorAll('$1')","description":"querySelectorAll"},
    "ce": {"body":"document.createElement('$1')","description":"createElement"},
    "st": {"body":"setTimeout(() => {\n\t$1\n}, $2);","description":"setTimeout"},
    "si": {"body":"setInterval(() => {\n\t$1\n}, $2);","description":"setInterval"},
    "af": {"body":"async function $1($2) {\n\t$3\n}","description":"Async Function"},
    "aaf": {"body":"const $1 = async ($2) => {\n\t$3\n};","description":"Async Arrow"},
    "req": {"body":"const $1 = require('$2');","description":"Require"}
  }
}
