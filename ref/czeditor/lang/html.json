{
  "id": "html",
  "name": "HTML",
  "extensions": ["html","htm","xhtml"],
  "comment": {"line":null,"blockStart":"<!--","blockEnd":"-->"},
  "autoClosePairs": [["\"","\""],["'","'"],["{","}"],["[","]"],["(",")"]],
  "autoCloseTag": true,
  "brackets": [["{","}"],["[","]"],["(",")"]],
  "emmet": true,
  "syntax": [
    {"match":"\"(?:[^\"\\\\]|\\\\.)*\"","scope":"string"},
    {"match":"'(?:[^'\\\\]|\\\\.)*'","scope":"string"},
    {"match":"<!--[\\s\\S]*?-->","scope":"comment"},
    {"match":"<!DOCTYPE[^>]*>","scope":"keyword"},
    {"match":"(?<=<\\/?)([a-zA-Z][a-zA-Z0-9-]*)","scope":"tag"},
    {"match":"\\b([a-zA-Z-]+)(?=\\s*=)","scope":"attr"},
    {"match":"[<>=/]","scope":"punctuation"}
  ],
  "autocomplete": {
    "keywords": [],
    "builtins": ["html","head","body","title","meta","link","script","style","div","span","p","a","img","h1","h2","h3","h4","h5","h6","ul","ol","li","table","tr","td","th","thead","tbody","tfoot","form","input","button","select","option","textarea","label","header","footer","nav","main","section","article","aside","figure","figcaption","details","summary","dialog","video","audio","source","canvas","svg","iframe","br","hr","pre","code","blockquote","em","strong","small","sub","sup","mark","del","ins","abbr","cite","dfn","fieldset","legend","datalist","output","progress","meter","template","slot","picture","map","area","track","embed","object","col","colgroup","caption","optgroup","ruby","rt","rp","class","id","style","src","href","alt","title","type","name","value","placeholder","action","method","target","rel","media","width","height","colspan","rowspan","disabled","readonly","required","checked","selected","data-","aria-","role","tabindex","lang","dir","onclick","onchange","onsubmit","onload","onerror","autocomplete","autofocus","multiple","pattern","min","max","step"]
  },
  "snippets": {
    "!": {"body":"<!DOCTYPE html>\n<html lang=\"id\">\n<head>\n\t<meta charset=\"UTF-8\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t<title>$1</title>\n</head>\n<body>\n\t$2\n</body>\n</html>","description":"HTML5 Boilerplate"},
    "link:css": {"body":"<link rel=\"stylesheet\" href=\"$1\">","description":"CSS Link"},
    "script:src": {"body":"<script src=\"$1\"></script>","description":"Script Tag"},
    "meta:vp": {"body":"<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">","description":"Viewport Meta"},
    "meta:desc": {"body":"<meta name=\"description\" content=\"$1\">","description":"Meta Description"},
    "meta:charset": {"body":"<meta charset=\"UTF-8\">","description":"Charset Meta"},
    "a:link": {"body":"<a href=\"$1\">$2</a>","description":"Anchor Link"},
    "a:blank": {"body":"<a href=\"$1\" target=\"_blank\" rel=\"noopener noreferrer\">$2</a>","description":"Blank Link"},
    "img": {"body":"<img src=\"$1\" alt=\"$2\">","description":"Image"},
    "input:text": {"body":"<input type=\"text\" name=\"$1\" id=\"$2\">","description":"Text Input"},
    "input:password": {"body":"<input type=\"password\" name=\"$1\" id=\"$2\">","description":"Password Input"},
    "input:email": {"body":"<input type=\"email\" name=\"$1\" id=\"$2\">","description":"Email Input"},
    "input:submit": {"body":"<input type=\"submit\" value=\"$1\">","description":"Submit Input"},
    "input:checkbox": {"body":"<input type=\"checkbox\" name=\"$1\" id=\"$2\">","description":"Checkbox"},
    "input:radio": {"body":"<input type=\"radio\" name=\"$1\" id=\"$2\">","description":"Radio"},
    "btn": {"body":"<button type=\"$1\">$2</button>","description":"Button"},
    "form:get": {"body":"<form action=\"$1\" method=\"GET\">\n\t$2\n</form>","description":"GET Form"},
    "form:post": {"body":"<form action=\"$1\" method=\"POST\">\n\t$2\n</form>","description":"POST Form"},
    "table+": {"body":"<table>\n\t<thead>\n\t\t<tr>\n\t\t\t<th>$1</th>\n\t\t</tr>\n\t</thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<td>$2</td>\n\t\t</tr>\n\t</tbody>\n</table>","description":"Full Table"},
    "ol+": {"body":"<ol>\n\t<li>$1</li>\n</ol>","description":"Ordered List"},
    "ul+": {"body":"<ul>\n\t<li>$1</li>\n</ul>","description":"Unordered List"},
    "dl+": {"body":"<dl>\n\t<dt>$1</dt>\n\t<dd>$2</dd>\n</dl>","description":"Definition List"},
    "pic": {"body":"<picture>\n\t<source srcset=\"$1\" media=\"$2\">\n\t<img src=\"$3\" alt=\"$4\">\n</picture>","description":"Picture"},
    "vid": {"body":"<video src=\"$1\" controls>\n\t$2\n</video>","description":"Video"},
    "aud": {"body":"<audio src=\"$1\" controls>\n\t$2\n</audio>","description":"Audio"}
  },
  "voidTags": ["area","base","br","col","embed","hr","img","input","link","meta","param","source","track","wbr"]
