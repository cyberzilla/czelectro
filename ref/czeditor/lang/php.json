  "snippets": {
    "php": {
      "body": "<?php\n$1\n?>",
      "description": "PHP Tags"
    },
    "echo": {
      "body": "echo $1;",
      "description": "Echo"
    },
    "fun": {
      "body": "function $1($2) {\n\t$3\n}",
      "description": "Function"
    },
    "cls": {
      "body": "class $1 {\n\tpublic function __construct($2) {\n\t\t$3\n\t}\n}",
      "description": "Class"
    },
    "if": {
      "body": "if ($1) {\n\t$2\n}",
      "description": "If"
    },
    "ife": {
      "body": "if ($1) {\n\t$2\n} else {\n\t$3\n}",
      "description": "If...Else"
    },
    "for": {
      "body": "for ($i = 0; $i < $1; $i++) {\n\t$2\n}",
      "description": "For"
    },
    "fore": {
      "body": "foreach ($1 as $2) {\n\t$3\n}",
      "description": "Foreach"
    },
    "tc": {
      "body": "try {\n\t$1\n} catch (Exception $e) {\n\t$2\n}",
      "description": "Try...Catch"
    },
    "sw": {
      "body": "switch ($1) {\n\tcase $2:\n\t\t$3\n\t\tbreak;\n\tdefault:\n\t\t$4\n}",
      "description": "Switch"
    }
  }
}