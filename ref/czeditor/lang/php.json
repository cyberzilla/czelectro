{
  "id": "php",
  "name": "PHP",
  "extensions": [
    "php",
    "phtml",
    "php3",
    "php4",
    "php5"
  ],
  "comment": {
    "line": "//",
    "blockStart": "/*",
    "blockEnd": "*/"
  },
  "autoClosePairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "syntax": [
    {
      "match": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "scope": "string"
    },
    {
      "match": "'(?:[^'\\\\]|\\\\.)*'",
      "scope": "string"
    },
    {
      "match": "\\/\\/[^\\n]*",
      "scope": "comment"
    },
    {
      "match": "#[^\\n]*",
      "scope": "comment"
    },
    {
      "match": "\\/\\*\\*[\\\\s\\\\S]*?\\*\\/",
      "scope": "doccomment"
    },
    {
      "match": "\\/\\*[\\s\\S]*?\\*\\/",
      "scope": "comment"
    },
    {
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*",
      "scope": "variable"
    },
    {
      "match": "\\b(?:abstract|and|as|break|callable|case|catch|class|clone|const|continue|declare|default|do|echo|else|elseif|empty|enddeclare|endfor|endforeach|endif|endswitch|endwhile|enum|extends|final|finally|fn|for|foreach|function|global|goto|if|implements|include|include_once|instanceof|insteadof|interface|isset|list|match|namespace|new|or|print|private|protected|public|readonly|require|require_once|return|static|switch|throw|trait|try|unset|use|var|while|xor|yield|true|false|null|self|parent|array|string|int|float|bool|void|mixed|never|object)\\b",
      "scope": "keyword"
    },
    {
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()",
      "scope": "function"
    },
    {
      "match": "\\b(?:0x[0-9a-fA-F]+|\\d+\\.?\\d*(?:e[+-]?\\d+)?)\\b",
      "scope": "number"
    },
    {
      "match": "(?:<\\?php|<\\?=|\\?>)",
      "scope": "tag"
    }
  ],
  "autocomplete": {
    "keywords": [
      "abstract",
      "and",
      "as",
      "break",
      "case",
      "catch",
      "class",
