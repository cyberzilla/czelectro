{
  "id": "python",
  "name": "Python",
  "extensions": ["py","pyw","pyi"],
  "comment": {"line":"#","blockStart":null,"blockEnd":null},
  "autoClosePairs": [["{","}"],["[","]"],["(",")"],["\"","\""],["'","'"]],
  "brackets": [["{","}"],["[","]"],["(",")"]],
  "indentOnChars": ":",
  "syntax": [
    {"match":"\"\"\"[\\s\\S]*?\"\"\"","scope":"string"},
    {"match":"'''[\\s\\S]*?'''","scope":"string"},
    {"match":"f\"(?:[^\"\\\\]|\\\\.)*\"","scope":"string"},
    {"match":"f'(?:[^'\\\\]|\\\\.)*'","scope":"string"},
    {"match":"\"(?:[^\"\\\\\\n]|\\\\.)*\"","scope":"string"},
    {"match":"'(?:[^'\\\\\\n]|\\\\.)*'","scope":"string"},
    {"match":"#[^\\n]*","scope":"comment"},
    {"match":"\\b(?:and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|nonlocal|not|or|pass|raise|return|try|while|with|yield|True|False|None)\\b","scope":"keyword"},
    {"match":"@[a-zA-Z_][a-zA-Z0-9_]*","scope":"decorator"},
    {"match":"\\b[A-Z][a-zA-Z0-9_]*\\b","scope":"class"},
    {"match":"\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()","scope":"function"},
    {"match":"\\b(?:0x[0-9a-fA-F]+|0b[01]+|0o[0-7]+|\\d+\\.?\\d*(?:e[+-]?\\d+)?)\\b","scope":"number"},
    {"match":"(?:==|!=|<=|>=|\\*\\*|//|<<|>>|<|>|&|\\||\\^|~)","scope":"operator"}
  ],
  "autocomplete": {
    "keywords": ["and","as","assert","async","await","break","class","continue","def","del","elif","else","except","finally","for","from","global","if","import","in","is","lambda","nonlocal","not","or","pass","raise","return","try","while","with","yield","True","False","None"],
    "builtins": ["print","len","range","type","int","float","str","list","dict","tuple","set","bool","input","open","enumerate","zip","map","filter","sorted","reversed","abs","max","min","sum","round","isinstance","issubclass","hasattr","getattr","setattr","delattr","property","staticmethod","classmethod","super","iter","next","callable","format","repr","hash","id","dir","vars","globals","locals","exec","eval","Exception","ValueError","TypeError","KeyError","IndexError","AttributeError","ImportError","FileNotFoundError","OSError","RuntimeError","StopIteration","NotImplementedError","__init__","__str__","__repr__","__len__","__getitem__","__setitem__","__delitem__","__iter__","__next__","__call__","__enter__","__exit__","__name__","__main__","__file__"]
  },
  "snippets": {
    "def": {"body":"def $1($2):\n\t$3","description":"Function"},
    "cls": {"body":"class $1:\n\tdef __init__(self, $2):\n\t\t$3","description":"Class"},
    "if": {"body":"if $1:\n\t$2","description":"If"},
    "ife": {"body":"if $1:\n\t$2\nelse:\n\t$3","description":"If...Else"},
    "elif": {"body":"elif $1:\n\t$2","description":"Elif"},
    "for": {"body":"for $1 in $2:\n\t$3","description":"For Loop"},
    "while": {"body":"while $1:\n\t$2","description":"While Loop"},
    "tc": {"body":"try:\n\t$1\nexcept $2:\n\t$3","description":"Try...Except"},
    "tcf": {"body":"try:\n\t$1\nexcept $2:\n\t$3\nfinally:\n\t$4","description":"Try...Except...Finally"},
    "with": {"body":"with $1 as $2:\n\t$3","description":"With"},
    "lc": {"body":"[$1 for $2 in $3]","description":"List Comprehension"},
    "dc": {"body":"{$1: $2 for $3 in $4}","description":"Dict Comprehension"},
    "lam": {"body":"lambda $1: $2","description":"Lambda"},
    "pr": {"body":"print($1)","description":"Print"},
    "prf": {"body":"print(f\"$1\")","description":"Print f-string"},
    "main": {"body":"if __name__ == \"__main__\":\n\t$1","description":"Main Guard"},
    "imp": {"body":"import $1","description":"Import"},
    "from": {"body":"from $1 import $2","description":"From Import"},
    "adef": {"body":"async def $1($2):\n\t$3","description":"Async Function"},
    "deco": {"body":"def $1(func):\n\tdef wrapper(*args, **kwargs):\n\t\t$2\n\t\treturn func(*args, **kwargs)\n\treturn wrapper","description":"Decorator"}
  }
}
